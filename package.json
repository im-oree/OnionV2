{
  "name": "onionv2",
  "private": true,
  "version": "0.1.0",
  "description": "Web-based 2D motion graphics application (After Effects functionality, Blender UI)",
  "author": "OnionV2",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:build-ts": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 -t 30000 && electron .\"",
    "electron:build": "rm -rf release && npm run build && npm run electron:build-ts && electron-builder",
    "electron:start": "npm run build && npm run electron:build-ts && electron ."
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "gifenc": "^1.0.3",
    "lucide-react": "^1.25.0",
    "mp4-muxer": "^5.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.168.0",
    "three-stdlib": "^2.36.1",
    "webm-muxer": "^5.1.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.168.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^9.1.0"
  },
  "build": {
    "appId": "com.onionv2.app",
    "productName": "OnionV2",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "asar": true,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
